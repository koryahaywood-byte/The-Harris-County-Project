# The Harris County Project — environment configuration
# Copy to .env.local for local dev; set the same vars in Vercel for production.
# Every tool degrades gracefully without its key (a labeled notice, never an
# error page or fake zeros), so configure only what you need.

# ── AI features ──────────────────────────────────────────────────────────────
# The Brief's city-council recap lede/timeline and the site chat widget.
# Without it: The Brief falls back to deterministic copy; chat is disabled.
ANTHROPIC_API_KEY=

# ── Legislative data (Bill Tracker + Congress Bills) ─────────────────────────
# Free key: https://legiscan.com/legiscan (register → API)
# Without it: both tools show a "requires configuration" notice.
LEGISCAN_API_KEY=

# ── Outside Money / PAC Tracker ───────────────────────────────────────────────
# Free key: https://api.data.gov/signup/ (works for api.fec.gov)
# Without it: falls back to DEMO_KEY (30 req/hr per IP) and may show the
# "FEC data unavailable" banner under load.
FEC_API_KEY=

# ── District demographics (CVAP refresh scripts) ─────────────────────────────
# Free key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ── Bluesky social feeds (The Brief) ─────────────────────────────────────────
# App password: https://bsky.app/settings/app-passwords
BSKY_IDENTIFIER=
BSKY_APP_PASSWORD=
NEXT_PUBLIC_BSKY_CONFIGURED=

# ── Contact form ──────────────────────────────────────────────────────────────
# Webhook (e.g. Zapier/Make) that receives contact + email-signup submissions.
EMAIL_WEBHOOK_URL=

# ── Canonical URL (OG images, share links) ────────────────────────────────────
SITE_URL=https://the-harris-county-project.vercel.app

# ── Voter file (Voter Search) — NOT an env var, a data file ──────────────────
# data/voters.db is a ~2.4M-row SQLite build of the public Harris County voter
# roll (Texas Election Code §18.008). It is gitignored for size; build it with:
#   VOTER_REG_FILE=<registration export> VOTER_HIST_FILE=<history export> \
#     node scripts/process-voter-file.mjs
# Without it: Voter Search shows "voter file not loaded on this deployment."
