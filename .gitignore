# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
data/finance-pdfs/*.pdf
data/finance-pdfs/_fetch-log.json
data/finance-processed/*.json

# Follow-an-Official subscriber store (PII — webhook is the durable copy)
data/follows/

# Community flags may carry contact info — webhook holds the durable copy
data/field-notes/flags.jsonl

# Bulk download scratch
data/tmp/
